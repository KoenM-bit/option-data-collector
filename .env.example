# Environment configuration example
# Copy this to .env and update with your production values

# Environment
ENVIRONMENT=production
ENV=production
TZ=Europe/Amsterdam

# Database (update with your Synology MySQL credentials)
DB_HOST=192.168.1.200
DB_USER=your_db_user
DB_PASSWORD=your_secure_password
DB_NAME=options_db
DB_PORT=3306

# Scraping
SCRAPE_INTERVAL=300  # 5 minutes for development
SLEEP_INTERVAL=60    # 1 minute when market closed
USER_AGENT=Mozilla/5.0

# Market hours
MARKET_OPEN=9
MARKET_CLOSE=17

# Ticker
TICKER=AD.AS

# API (if you add an API service later)
API_PORT=8000
API_HOST=0.0.0.0