# Environment configuration example
# Copy this to .env for local development

# Environment
ENV=development
TZ=Europe/Amsterdam

# Database (development defaults)
DB_HOST=localhost
DB_USER=root
DB_PASS=devpassword
DB_NAME=optionsdb_dev
DB_PORT=3306

# Scraping
SCRAPE_INTERVAL=300  # 5 minutes for development
SLEEP_INTERVAL=60    # 1 minute when market closed
USER_AGENT=Mozilla/5.0

# Market hours
MARKET_OPEN=9
MARKET_CLOSE=17

# Ticker
TICKER=AD.AS

# API (if you add an API service later)
API_PORT=8000
API_HOST=0.0.0.0