[flake8]
max-line-length = 88
extend-ignore = 
    E203,
    E501,
    W503,
    F401
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    .env,
    archive,
    docker,
    .pytest_cache,
    .mypy_cache
per-file-ignores =
    __init__.py:F401
    */migrations/*:E501
    */settings/*:E501